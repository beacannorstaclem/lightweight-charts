{
  "name": "lightweight-charts",
  "version": "4.2.0",
  "description": "Performant financial charts built with HTML5 canvas",
  "keywords": [
    "charts",
    "financial",
    "canvas",
    "trading",
    "typescript"
  ],
  "homepage": "https://github.com/tradingview/lightweight-charts",
  "bugs": {
    "url": "https://github.com/tradingview/lightweight-charts/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tradingview/lightweight-charts.git"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "dist/lightweight-charts.standalone.development.js",
  "module": "dist/lightweight-charts.production.mjs",
  "types": "dist/typings.d.ts",
  "exports": {
    ".": {
      "types": "./dist/typings.d.ts",
      "import": "./dist/lightweight-charts.production.mjs",
      "require": "./dist/lightweight-charts.standalone.production.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --noEmit && rollup -c",
    "build:dev": "rollup -c --environment BUILD:development",
    "lint": "eslint --ext .ts src/",
    "lint:fix": "eslint --ext .ts src/ --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "node tests/e2e/runner.js",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --options typedoc.config.cjs",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.0.4",
    "jest": "^29.7.0",
    "rollup": "^4.9.5",
    "rollup-plugin-dts": "^6.1.0",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.2",
    "typedoc": "^0.25.7",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
